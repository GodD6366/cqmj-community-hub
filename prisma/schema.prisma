generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostCategory {
  request
  secondhand
  discussion
  play
}

enum VisibilityScope {
  community
  building
  private
}

enum PostStatus {
  published
  pending
  rejected
}

enum UserRole {
  user
  admin
}

enum PollStatus {
  active
  closed
}

enum ServiceTicketCategory {
  repair
  complaint
  cleaning
  facility
  other
}

enum ServiceTicketStatus {
  open
  processing
  resolved
}

enum NotificationType {
  comment
  favorite
  poll
  ticket
  group
  system
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  name             String
  roomNumber       String?
  passwordHash     String
  role             UserRole          @default(user)
  disabledAt       DateTime?
  mcpTokenVersion  Int               @default(0)
  mcpTokenIssuedAt DateTime?
  mcpGuideSeenAt   DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         Session[]
  posts            Post[]
  comments         Comment[]
  favorites        Favorite[]
  reports          Report[]
  polls            Poll[]
  pollVotes        PollVote[]
  serviceTickets   ServiceTicket[]
  notifications    Notification[]

  @@index([roomNumber])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Post {
  id            String           @id @default(cuid())
  title         String
  content       String
  category      PostCategory
  tags          String           @default("[]")
  authorName    String
  authorId      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  commentCount  Int              @default(0)
  favoriteCount Int              @default(0)
  visibility    VisibilityScope
  status        PostStatus       @default(published)
  pinned        Boolean          @default(false)
  featured      Boolean          @default(false)
  author        User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments      Comment[]
  favorites     Favorite[]
  images        PostImage[]
  reports       Report[]

  @@index([status, visibility])
  @@index([createdAt])
  @@index([authorId])
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  objectKey String
  url       String
  mimeType  String
  width     Int
  height    Int
  sizeBytes Int
  sortOrder Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  authorName String
  authorId   String?
  content    String
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt])
  @@index([authorId])
}

model Favorite {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([postId])
}

model Report {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([postId])
}

model Poll {
  id          String       @id @default(cuid())
  title       String
  description String
  authorName  String
  authorId    String?
  status      PollStatus   @default(active)
  endsAt      DateTime?
  totalVotes  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  options     PollOption[]
  votes       PollVote[]

  @@index([status, createdAt])
  @@index([authorId])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int
  voteCount Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@index([pollId, sortOrder])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
  @@index([userId])
}

model ServiceTicket {
  id           String                @id @default(cuid())
  title        String
  description  String
  category     ServiceTicketCategory
  status       ServiceTicketStatus   @default(open)
  authorName   String
  roomNumber   String?
  authorId     String?
  assigneeNote String?
  resolvedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  author       User?                 @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([authorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  note      String?
  active    Boolean  @default(true)
  maxUses   Int?
  usedCount Int      @default(0)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
